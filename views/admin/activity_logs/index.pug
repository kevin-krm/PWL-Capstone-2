extends ../../layouts/master
include ../../partials/dt-assets

block styles
    +dtStyles

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1.m-0 Riwayat Audit Penuh (Activity Log)
                .col-sm-6
                    ol.breadcrumb.float-sm-right
                        li.breadcrumb-item
                            a(href="/admin/dashboard") Dashboard
                        li.breadcrumb-item.active Riwayat Audit Penuh

    .content
        .container-fluid
            .card.card-primary.card-outline
                .card-header
                    h3.card-title
                        i.fas.fa-history.mr-1
                        | Log Aktivitas Pengguna
                .card-body
                    .row.mb-3
                        .col-md-3
                            label.small.mb-1.text-muted Role
                            select#filter-role.form-control.form-control-sm
                                option(value="") Semua Role
                                option(value="Administrator") Administrator
                                option(value="Kepala Laboratorium") Kepala Laboratorium
                                option(value="Ketua Program Studi") Ketua Program Studi
                                option(value="Staf Administrasi") Staf Administrasi
                                option(value="Staf Laboratorium") Staf Laboratorium
                        .col-md-3
                            label.small.mb-1.text-muted Aksi
                            select#filter-action.form-control.form-control-sm
                                option(value="") Semua Aksi
                        .col-md-3.d-flex.align-items-end
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter

                    table#auditTable.table.table-bordered.table-hover.table-striped(style="width:100%")
                        thead.thead-dark
                            tr
                                th No
                                th Waktu
                                th Pengguna
                                th Role
                                th Aksi
                                th Deskripsi Detail
                        tbody
                            each log, index in logs
                                tr
                                    td.text-center= index + 1
                                    td(data-order=(log.created_at ? new Date(log.created_at).getTime() : 0))= new Date(log.created_at).toLocaleString('id-ID')
                                    td
                                        if log.user_name
                                            strong #{log.user_name}
                                            br
                                            small.text-muted #{log.user_role}
                                        else
                                            span.text-danger Sistem / Terhapus
                                    td= log.user_role || '-'
                                    td
                                        span.badge.badge-info #{log.action}
                                    td= log.description

block scripts
    +dtScripts
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };
            var table = $('#auditTable').DataTable({
                language: lang,
                pageLength: 10, lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Semua']],
                stateSave: true, stateDuration: -1,
                order: [[1, 'desc']],
                columnDefs: [
                    { targets: 0, orderable: false, searchable: false },
                    { targets: 3, visible: false }   // kolom Role tersembunyi (dipakai filter)
                ]
            });
            table.on('draw.dt', function () {
                table.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });

            // Isi dropdown Aksi dari nilai unik kolom Aksi (col 4)
            table.column(4).data().unique().sort().each(function (d) {
                var t = $('<div>').html(d).text().trim();
                if (t) $('#filter-action').append($('<option>').val(t).text(t));
            });

            function exact(v) { return v ? '^' + $.fn.dataTable.util.escapeRegex(v) + '$' : ''; }
            function unanchor(s) { return s ? s.replace(/^\^/, '').replace(/\$$/, '').replace(/\\(.)/g, '$1') : ''; }
            $('#filter-role').on('change',   function () { table.column(3).search(exact(this.value), true, false).draw(); });
            $('#filter-action').on('change', function () { table.column(4).search(exact(this.value), true, false).draw(); });

            $('#btn-reset-filter').on('click', function () {
                $('#filter-role, #filter-action').val('');
                $('#auditTable_filter input').val('');
                table.search('').columns().search('').order([[1, 'desc']]).draw();
            });

            // Sinkron dropdown dari state tersimpan (stateSave)
            $('#filter-role').val(unanchor(table.column(3).search()));
            $('#filter-action').val(unanchor(table.column(4).search()));

            table.draw();
        });

extends ../../layouts/master

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1.m-0 Riwayat Audit Penuh (Activity Log)
                .col-sm-6
                    ol.breadcrumb.float-sm-right
                        li.breadcrumb-item
                            a(href="/admin/dashboard") Dashboard
                        li.breadcrumb-item.active Riwayat Audit Penuh

    .content
        .container-fluid
            .card.card-primary.card-outline
                .card-header
                    h3.card-title 
                        i.fas.fa-history.mr-1
                        | Log Aktivitas Pengguna
                .card-body
                    form.row.mb-3(method="GET" action="/admin/activity-logs")
                        .col-md-2
                            select.form-control.form-control-sm(name="sort" onchange="this.form.submit()")
                                option(value="desc" selected=(selectedSort !== 'asc')) Waktu (Terbaru)
                                option(value="asc" selected=(selectedSort === 'asc')) Waktu (Terlama)
                        .col-md-3
                            select.form-control.form-control-sm(name="role" onchange="this.form.submit()")
                                option(value="" selected=(!selectedRole)) Semua Role
                                option(value="Administrator" selected=(selectedRole == 'Administrator')) Administrator
                                option(value="Kepala Laboratorium" selected=(selectedRole == 'Kepala Laboratorium')) Kepala Laboratorium
                                option(value="Ketua Program Studi" selected=(selectedRole == 'Ketua Program Studi')) Ketua Program Studi
                                option(value="Staf Administrasi" selected=(selectedRole == 'Staf Administrasi')) Staf Administrasi
                                option(value="Staf Laboratorium" selected=(selectedRole == 'Staf Laboratorium')) Staf Laboratorium
                        .col-md-2
                            select.form-control.form-control-sm(name="action" onchange="this.form.submit()")
                                option(value="" selected=(!selectedAction)) Semua Aksi
                                option(value="Membuat Draft Pengadaan" selected=(selectedAction == 'Membuat Draft Pengadaan')) Membuat Draft Pengadaan
                                option(value="Lock Draft Pengadaan" selected=(selectedAction == 'Lock Draft Pengadaan')) Lock Draft Pengadaan
                                option(value="Register Aset" selected=(selectedAction == 'Register Aset')) Register Aset
                        .col-md-3
                            .input-group.input-group-sm
                                input.form-control(type="text" name="search" placeholder="Cari..." value=searchQuery)
                                .input-group-append
                                    button.btn.btn-primary(type="submit")
                                        i.fas.fa-search
                        .col-md-2
                            a.btn.btn-secondary.btn-sm.btn-block(href="/admin/activity-logs")
                                i.fas.fa-undo
                                |  Reset Filter
                    .table-responsive
                        table.table.table-bordered.table-hover.table-striped
                            thead.thead-dark
                                tr
                                    th(width="5%") No
                                    th(width="15%") Waktu
                                    th(width="25%") Pengguna
                                    th(width="15%") Aksi
                                    th(width="40%") Deskripsi Detail
                            tbody
                                if logs.length > 0
                                    each log, index in logs
                                        tr
                                            td.text-center #{index + 1}
                                            td #{new Date(log.created_at).toLocaleString('id-ID')}
                                            td
                                                if log.user_name
                                                    strong #{log.user_name}
                                                    br
                                                    small.text-muted #{log.user_role}
                                                else
                                                    span.text-danger Sistem / Terhapus
                                            td
                                                span.badge.badge-info #{log.action}
                                            td #{log.description}
                                else
                                    tr
                                        td.text-center(colspan="5") Belum ada riwayat aktivitas yang dicatat.

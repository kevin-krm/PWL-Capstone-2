extends ../layouts/master

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Data Inventaris Laboratorium

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Daftar Aset GWT 8
                .card-body
                    form.row.mb-3(method="GET" action="/stafadmin/assets")
                        .col-md-3
                            select.form-control.form-control-sm(name="condition" onchange="this.form.submit()")
                                option(value="" selected=(!selectedCondition)) Semua Kondisi
                                option(value="Baik" selected=(selectedCondition == 'Baik')) Baik
                                option(value="Rusak" selected=(selectedCondition == 'Rusak')) Rusak
                                option(value="Maintenance" selected=(selectedCondition == 'Maintenance')) Maintenance
                                option(value="Dihapus" selected=(selectedCondition == 'Dihapus')) Dihapus
                        .col-md-3
                            select.form-control.form-control-sm(name="active" onchange="this.form.submit()")
                                option(value="" selected=(!selectedActive)) Semua Status Aktif
                                option(value="active" selected=(selectedActive == 'active')) Aktif
                                option(value="inactive" selected=(selectedActive == 'inactive')) Nonaktif
                        .col-md-3
                            select.form-control.form-control-sm(name="sort" onchange="this.form.submit()")
                                option(value="" selected=(!selectedSort)) Urutkan
                                option(value="abjad" selected=(selectedSort == 'abjad')) Abjad (A-Z)
                                option(value="recent" selected=(selectedSort == 'recent')) Terbaru
                        .col-md-3
                            a.btn.btn-secondary.btn-sm.btn-block(href="/stafadmin/assets")
                                i.fas.fa-undo
                                |  Reset Filter

                    table.table.table-bordered
                        thead
                            tr.bg-primary
                                th No.
                                th Kode Label
                                th QR Code
                                th Nama Barang
                                th Lokasi Ruangan
                                th Kondisi
                                th Status Aktif
                                th Aksi
                        tbody
                            each a, index in assets
                                tr
                                    td= index + 1
                                    td= a.label_code
                                    td.text-center
                                        if a.qr_code_url
                                            img(src=a.qr_code_url alt=a.label_code style="width: 80px; height: 80px;")
                                        else
                                            span.text-muted -
                                    td= a.item_name
                                    td= a.room_name ? a.room_name : 'Belum Ditempatkan'
                                    td
                                        if a.condition_status == 'Baik'
                                            span.badge.badge-success Baik
                                        else if a.condition_status == 'Rusak'
                                            span.badge.badge-danger Rusak
                                        else if a.condition_status == 'Maintenance'
                                            span.badge.badge-warning Maintenance
                                        else
                                            span.badge.badge-secondary Dihapus
                                    td= a.is_active ? 'Ya' : 'Tidak'
                                    td
                                        a.btn.btn-sm.btn-warning(href=`/stafadmin/assets/edit/${a.id}`) Edit
                                        form(action=`/stafadmin/assets/delete/${a.id}` method="POST" style="display:inline;")
                                            button.btn.btn-sm.btn-danger.ml-1(type="submit" onclick="return confirm('Yakin ingin menghapus aset ini?');") Hapus
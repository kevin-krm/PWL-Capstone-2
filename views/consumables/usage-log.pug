extends ../layouts/master
include ../partials/dt-assets

block styles
    +dtStyles

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Log Riwayat Pemakaian BHP
                .col-sm-6
                    ol.breadcrumb.float-sm-right
                        li.breadcrumb-item
                            a(href="/staflab/consumables") Daftar BHP
                        li.breadcrumb-item.active Riwayat Pemakaian

    .content
        .container-fluid
            .card.card-primary.card-outline
                .card-header
                    h3.card-title
                        i.fas.fa-history.mr-1
                        | Riwayat Pemakaian BHP per Aset & Ruangan
                .card-body
                    .row.mb-3
                        .col-md-3
                            label.small.mb-1.text-muted Ruangan
                            select#filter-room.form-control.form-control-sm
                                option(value="") Semua Ruangan
                        .col-md-3
                            label.small.mb-1.text-muted Urutkan
                            select#filter-sort.form-control.form-control-sm
                                option(value="") Default
                                option(value="abjad") Abjad (A-Z)
                                option(value="recent") Terbaru
                        .col-md-3.d-flex.align-items-end
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter
                    table#usageLogTable.table.table-striped.table-bordered(style="width:100%")
                        thead
                            tr.bg-primary
                                th.text-center(style="width: 5%") No.
                                th Nama BHP
                                th.text-center(style="width: 8%") Jumlah
                                th.text-center(style="width: 8%") Satuan
                                th Nama Aset
                                th(style="width: 12%") Kode Label
                                th(style="width: 16%") Ruangan
                                th.text-center(style="width: 12%") Tanggal
                                th(style="width: 14%") Petugas
                        tbody
                            each u, index in usages
                                tr
                                    td.text-center= index + 1
                                    td.font-weight-bold= u.consumable_name
                                    td.text-center= u.quantity_used
                                    td.text-center= u.unit
                                    td= u.asset_name
                                    td
                                        code= u.label_code || '-'
                                    td= u.room_name || 'Belum Ditempatkan'
                                    td.text-center(data-order=(u.maintenance_date ? new Date(u.maintenance_date).getTime() : 0))= u.maintenance_date ? new Date(u.maintenance_date).toLocaleDateString('id-ID') : '-'
                                    td= u.staf_name

block scripts
    +dtScripts
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };
            var table = $('#usageLogTable').DataTable({
                language: lang,
                pageLength: 10, lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Semua']],
                stateSave: true, stateDuration: -1,
                order: [[7, 'desc']],
                columnDefs: [{ targets: 0, orderable: false, searchable: false }]
            });
            table.on('draw.dt', function () {
                table.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });

            function exact(v) { return v ? '^' + $.fn.dataTable.util.escapeRegex(v) + '$' : ''; }
            function unanchor(s) { return s ? s.replace(/^\^/, '').replace(/\$$/, '').replace(/\\(.)/g, '$1') : ''; }

            // Isi dropdown Ruangan dari nilai unik kolom Ruangan (col 6)
            table.column(6).data().unique().sort().each(function (d) {
                var t = $('<div>').html(d).text().trim();
                if (t) $('#filter-room').append($('<option>').val(t).text(t));
            });

            $('#filter-room').on('change', function () { table.column(6).search(exact(this.value), true, false).draw(); });
            $('#filter-sort').on('change', function () {
                if (this.value === 'abjad') table.order([1, 'asc']).draw();
                else table.order([7, 'desc']).draw();
            });

            $('#btn-reset-filter').on('click', function () {
                $('#filter-room, #filter-sort').val('');
                $('#usageLogTable_filter input').val('');
                table.search('').columns().search('').order([[7, 'desc']]).draw();
            });

            // Sinkron dropdown dari state tersimpan (stateSave)
            $('#filter-room').val(unanchor(table.column(6).search()));
            (function () {
                var o = table.order();
                if (o && o.length && o[0][0] === 1 && o[0][1] === 'asc') $('#filter-sort').val('abjad');
                else if (o && o.length && o[0][0] === 7 && o[0][1] === 'desc') $('#filter-sort').val('recent');
                else $('#filter-sort').val('');
            })();

            table.draw();
        });

doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1")
        title Capstone Lab Inventory

        // Google Font: Source Sans Pro
        link(rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback")
        // Font Awesome
        link(rel="stylesheet" href="/adminlte/plugins/fontawesome-free/css/all.min.css")
        // Theme style
        link(rel="stylesheet" href="/adminlte/dist/css/adminlte.min.css")
        
        style.
            /* Custom Active Sidebar Style */
            .nav-sidebar .nav-item > .nav-link.active-sidebar {
                box-shadow: inset 4px 0 0 #007bff;
                background-color: rgba(255,255,255,.05) !important;
                color: #fff !important;
            }

        // CSS khusus per halaman (mis. DataTables)
        block styles

    body.hold-transition.sidebar-mini.layout-fixed.layout-navbar-fixed.layout-footer-fixed
        .wrapper
            // Menyisipkan Header
            include header.pug

            // Menyisipkan Sidebar
            include sidebar.pug

            // Content Wrapper
            .content-wrapper
                block content

            // Menyisipkan Footer
            include footer.pug

        // jQuery
        script(src="/adminlte/plugins/jquery/jquery.min.js")
        // Bootstrap 4
        script(src="/adminlte/plugins/bootstrap/js/bootstrap.bundle.min.js")
        // AdminLTE App
        script(src="/adminlte/dist/js/adminlte.min.js")

        // Script khusus per halaman (mis. Chart.js pada Dashboard)
        block scripts

        script.
            $(document).ready(function() {
                var currentUrl = window.location.href;
                $('.nav-sidebar a.nav-link').each(function() {
                    var href = $(this).attr('href');
                    if (href && href !== '#' && href !== '/') {
                        // Check if current URL contains the href to keep it highlighted on sub-pages (create/edit)
                        if (currentUrl.includes(href)) {
                            // Specific check for dashboard to avoid matching other routes if they share a common prefix
                            if (href === '/admin/dashboard' && !currentUrl.endsWith('/admin/dashboard')) {
                                return; 
                            }
                            $(this).addClass('active-sidebar');
                        }
                    }
                });
            });

        // Reset Filter: biru primary + enabled saat ada filter/sort aktif, abu-abu
        // (secondary) + disabled saat default. Status mengikuti AKSI pengguna (flag
        // dirty: klik header sort / ubah dropdown / ketik pencarian) sehingga sort ke
        // urutan default (mis. nama-asc) tetap mengaktifkan tombol — konsisten untuk
        // semua sort/filter. Direset saat tombol Reset ditekan. State DataTables
        // tersimpan (stateSave) tetap dianggap aktif saat reload.
        script.
            $(function () {
                var $btn = $('#btn-reset-filter');
                if (!$btn.length || !$.fn.dataTable) return;

                var dirty = false;

                function orderChanged(api) {
                    var s = api.settings()[0];
                    var def = (s && s.oInit && s.oInit.order) ? s.oInit.order : [[0, 'asc']];
                    return JSON.stringify(api.order()) !== JSON.stringify(def);
                }
                function stateNotPristine() {
                    var active = false;
                    $('table').each(function () {
                        if (!$.fn.dataTable.isDataTable(this)) return;
                        var api = $(this).DataTable();
                        if (api.search()) { active = true; return; }            // pencarian global
                        var col = false;
                        api.columns().search().each(function (v) { if (v) col = true; }); // pencarian kolom
                        if (col || orderChanged(api)) active = true;             // sorting != default
                    });
                    return active;
                }
                function sync() {
                    var on = dirty || stateNotPristine();
                    $btn.prop('disabled', !on)
                        .toggleClass('btn-primary', on)
                        .toggleClass('btn-secondary', !on);
                }
                function markDirty() { dirty = true; sync(); }

                // Aksi pengguna => tombol aktif (termasuk sort ke urutan default seperti nama-asc):
                $(document).on('change', 'select[id^="filter-"]', markDirty);                 // dropdown filter & Urutkan
                $(document).on('input keyup search', '.dataTables_filter input', markDirty);  // kotak pencarian global
                $(document).on('click', 'thead th.sorting, thead th.sorting_asc, thead th.sorting_desc', markDirty); // klik header sort

                // Reset universal: kembalikan SEMUA filter/pencarian/urutan tiap tabel ke
                // default, lalu paksa tombol ke state abu-abu & nonaktif (tidak dapat ditekan).
                function resetAll() {
                    $('select[id^="filter-"]').val('');            // dropdown filter & Urutkan
                    $('.dataTables_filter input').val('');         // kotak pencarian global
                    $('table').each(function () {
                        if (!$.fn.dataTable.isDataTable(this)) return;
                        var api = $(this).DataTable();
                        var s = api.settings()[0];
                        var def = (s && s.oInit && s.oInit.order) ? s.oInit.order : [[0, 'asc']];
                        api.search('').columns().search('').order(def).draw();
                    });
                    dirty = false;
                    sync();
                }
                $btn.on('click', resetAll);

                setTimeout(sync, 0); // sinkron awal: aktif hanya bila state tersimpan bukan default
            });
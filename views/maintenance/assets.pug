extends ../layouts/master

block styles
    link(rel="stylesheet" href="/adminlte/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css")
    link(rel="stylesheet" href="/adminlte/plugins/datatables-buttons/css/buttons.bootstrap4.min.css")
    link(rel="stylesheet" href="/adminlte/plugins/datatables-select/css/select.bootstrap4.min.css")
    style.
        .toggle-select-btn.active { background-color: #007bff !important; color: #fff !important; border-color: #007bff !important; }
        #universal-select-wrapper { display: none; }
        #universal-select-wrapper.visible { display: flex !important; align-items: center; }

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1.m-0 Data Inventaris Laboratorium
                .col-sm-6
                    - var homeHref = '/staflab/consumables'
                    if user.role === 'Kepala Laboratorium'
                        - homeHref = '/kalab/procurement-drafts'
                    else if user.role === 'Ketua Program Studi'
                        - homeHref = '/kaprodi/procurement-review'
                    ol.breadcrumb.float-sm-right
                        li.breadcrumb-item
                            a(href=homeHref) Home
                        li.breadcrumb-item.active Data Inventaris

    .content
        .container-fluid
            .card.card-primary.card-outline
                .card-header
                    h3.card-title
                        i.fas.fa-desktop.mr-1
                        | Daftar Aset Laboratorium GWT 8
                .card-body
                    //- Filter canggih (client-side DataTables)
                    .row.mb-3
                        .col-md-3
                            label.small.mb-1.text-muted Kondisi
                            select#filter-condition.form-control.form-control-sm
                                option(value="") Semua Kondisi
                                option(value="Baik") Baik
                                option(value="Rusak") Rusak
                                option(value="Maintenance") Maintenance
                                option(value="Dihapus") Dihapus
                        .col-md-3
                            label.small.mb-1.text-muted Ruangan
                            select#filter-room.form-control.form-control-sm
                                option(value="") Semua Ruangan
                        .col-md-3
                            label.small.mb-1.text-muted Urutkan
                            select#filter-sort.form-control.form-control-sm
                                option(value="") Default
                                option(value="abjad") Abjad (A-Z)
                                option(value="recent") Terbaru
                        .col-md-3.d-flex.align-items-end
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter

                    .table-responsive
                        table#assetsTable.table.table-striped.table-bordered(style="width:100%")
                            thead
                                tr.bg-primary
                                    th
                                    th.text-center No.
                                    th Kode Label
                                    th Nama Barang
                                    th Lokasi Ruangan
                                    th.text-center Kondisi
                                    th.text-center Aksi
                                    th.d-none Ditambahkan
                            tbody
                                each a, index in assets
                                    tr
                                        td
                                        td.text-center= index + 1
                                        td
                                            code= a.label_code || '-'
                                        td.font-weight-bold= a.item_name
                                        td= a.room_name ? a.room_name : 'Belum Ditempatkan'
                                        td.text-center
                                            if a.condition_status == 'Baik'
                                                span.badge.badge-success.p-2
                                                    i.fas.fa-check-circle.mr-1
                                                    | Baik
                                            else if a.condition_status == 'Rusak'
                                                span.badge.badge-danger.p-2
                                                    i.fas.fa-times-circle.mr-1
                                                    | Rusak
                                            else if a.condition_status == 'Maintenance'
                                                span.badge.badge-warning.p-2
                                                    i.fas.fa-wrench.mr-1
                                                    | Maintenance
                                            else
                                                span.badge.badge-secondary.p-2
                                                    i.fas.fa-ban.mr-1
                                                    | Dihapus
                                        td.text-center
                                            if user.role === 'Staf Laboratorium' && a.condition_status !== 'Baik'
                                                a.btn.btn-sm.btn-info(href=`/staflab/assets/maintenance/${a.id}`)
                                                    i.fas.fa-tools.mr-1
                                                    | Maintenance
                                            else
                                                span.text-muted -
                                        td.d-none(data-order=(a.created_at ? new Date(a.created_at).getTime() : a.id))

block scripts
    script(src="/adminlte/plugins/datatables/jquery.dataTables.min.js")
    script(src="/adminlte/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js")
    script(src="/adminlte/plugins/datatables-buttons/js/dataTables.buttons.min.js")
    script(src="/adminlte/plugins/datatables-buttons/js/buttons.bootstrap4.min.js")
    script(src="/adminlte/plugins/jszip/jszip.min.js")
    script(src="/adminlte/plugins/pdfmake/pdfmake.min.js")
    script(src="/adminlte/plugins/pdfmake/vfs_fonts.js")
    script(src="/adminlte/plugins/datatables-buttons/js/buttons.html5.min.js")
    script(src="/adminlte/plugins/datatables-buttons/js/buttons.print.min.js")
    script(src="/adminlte/plugins/datatables-select/js/dataTables.select.min.js")
    script(src="/adminlte/plugins/datatables-select/js/select.bootstrap4.min.js")
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };

            // Columns to export (skip 0=checkbox, 6=Aksi)
            var exportCols = [2, 3, 4, 5];
            var selectMode = false;
            var exportRowsSetting = function (idx, data, node) {
                var dt = $('#assetsTable').DataTable();
                if (selectMode && dt.rows({ selected: true }).count() > 0) {
                    return dt.rows({ selected: true }).indexes().toArray().indexOf(idx) !== -1;
                }
                return true;
            };

            var table = $('#assetsTable').DataTable({
                dom: "<'row align-items-center mb-2'" +
                     "<'col-auto'<'#toggle-select-container'>>" +
                     "<'col-auto'<'#universal-select-wrapper'>>" +
                     "<'col-auto'B>" +
                     "<'col'>" +
                     "<'col-auto'l>" +
                     "<'col-auto'f>" +
                     ">rt<'row'<'col-sm-5'i><'col-sm-7'p>>",
                buttons: [
                    { extend: 'copy',  text: '<i class="fas fa-copy"></i> Copy',   className: 'btn btn-sm btn-secondary', exportOptions: { columns: exportCols, rows: exportRowsSetting } },
                    { extend: 'excel', text: '<i class="fas fa-file-excel"></i> Excel', className: 'btn btn-sm btn-success', exportOptions: { columns: exportCols, rows: exportRowsSetting } },
                    { extend: 'pdf',   text: '<i class="fas fa-file-pdf"></i> PDF', className: 'btn btn-sm btn-danger',  exportOptions: { columns: exportCols, rows: exportRowsSetting } },
                    { extend: 'print', text: '<i class="fas fa-print"></i> Print', className: 'btn btn-sm btn-info',    exportOptions: { columns: exportCols, rows: exportRowsSetting } }
                ],
                select: { style: 'api', selector: 'td:first-child', info: false },
                pageLength: 10, lengthMenu: [[5, 10, 25, -1], [5, 10, 25, 'Semua']], order: [[3,'asc']], language: lang, stateSave: true, stateDuration: -1,
                columnDefs: [
                    { targets: 0, orderable: false, searchable: false, className: 'select-checkbox', visible: false },
                    { targets: [1, 6], orderable: false, searchable: false },
                    { targets: 7, visible: false, searchable: false }
                ],
                initComplete: function () {
                    // --- Toggle Select Button ---
                    $('#toggle-select-container').html(
                        '<button id="btnToggleSelect" class="btn btn-sm btn-outline-secondary toggle-select-btn" title="Toggle Select Mode">' +
                        '<i class="fas fa-check-square mr-1"></i>Select</button>'
                    );

                    // --- Universal Select Checkbox ---
                    $('#universal-select-wrapper').html(
                        '<input type="checkbox" id="selectAllRows" class="mr-1" style="cursor:pointer;"> ' +
                        '<label for="selectAllRows" class="mb-0 small text-muted" style="cursor:pointer;white-space:nowrap;">Pilih Semua</label>'
                    );

                    // --- Toggle ON/OFF ---
                    $('#btnToggleSelect').on('click', function () {
                        selectMode = !selectMode;
                        $(this).toggleClass('active', selectMode);
                        if (selectMode) {
                            table.column(0).visible(true);
                            table.select.style('multi');
                            $('#universal-select-wrapper').addClass('visible');
                        } else {
                            table.rows().deselect();
                            table.select.style('api');
                            table.column(0).visible(false);
                            $('#universal-select-wrapper').removeClass('visible');
                            var chk = document.getElementById('selectAllRows');
                            if (chk) { chk.checked = false; chk.indeterminate = false; }
                        }
                    });

                    // --- Pilih Semua ---
                    $('#universal-select-wrapper').on('change', '#selectAllRows', function () {
                        if (this.checked) {
                            table.rows({ search: 'applied' }).select();
                        } else {
                            table.rows().deselect();
                        }
                    });
                }
            });

            // --- Universal checkbox state sync ---
            table.on('select.dt deselect.dt', function () {
                var chk = document.getElementById('selectAllRows');
                if (!chk || !selectMode) return;
                var total = table.rows({ search: 'applied' }).count();
                var selected = table.rows({ selected: true }).count();
                if (selected === 0) { chk.checked = false; chk.indeterminate = false; }
                else if (selected >= total) { chk.checked = true; chk.indeterminate = false; }
                else { chk.checked = false; chk.indeterminate = true; }
            });

            // --- Row numbering ---
            table.on('draw.dt', function () {
                table.column(1, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });

            function exact(v) { return v ? '^' + $.fn.dataTable.util.escapeRegex(v) + '$' : ''; }
            function unanchor(s) { return s ? s.replace(/^\^/, '').replace(/\$$/, '').replace(/\\(.)/g, '$1') : ''; }

            // Isi dropdown Ruangan dari nilai unik kolom Lokasi Ruangan (col 4)
            table.column(4).data().unique().sort().each(function (d) {
                var t = $('<div>').html(d).text().trim();
                if (t) $('#filter-room').append($('<option>').val(t).text(t));
            });

            $('#filter-condition').on('change', function () { table.column(5).search(this.value, false, true).draw(); });
            $('#filter-room').on('change', function () { table.column(4).search(exact(this.value), true, false).draw(); });
            $('#filter-sort').on('change', function () {
                if (this.value === 'recent') table.order([7, 'desc']).draw();
                else table.order([3, 'asc']).draw();
            });

            $('#btn-reset-filter').on('click', function () {
                $('#filter-condition, #filter-room, #filter-sort').val('');
                $('#assetsTable_filter input').val('');
                table.search('').columns().search('').order([[3,'asc']]).draw();
            });

            // Sinkron dropdown dari state tersimpan (stateSave); kolom checkbox tetap tersembunyi
            $('#filter-condition').val(table.column(5).search());
            $('#filter-room').val(unanchor(table.column(4).search()));
            (function () {
                var o = table.order();
                if (o && o.length && o[0][0] === 7 && o[0][1] === 'desc') $('#filter-sort').val('recent');
                else if (o && o.length && o[0][0] === 3 && o[0][1] === 'asc') $('#filter-sort').val('abjad');
                else $('#filter-sort').val('');
            })();
            table.column(0).visible(false);

            table.draw();
        });

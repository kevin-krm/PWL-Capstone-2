extends ../layouts/master
include ../partials/dt-assets

block styles
    +dtStyles
    style.
        td.dt-expand-cell { cursor: pointer; }

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1.m-0 Log Maintenance
                .col-sm-6
                    ol.breadcrumb.float-sm-right
                        li.breadcrumb-item
                            a(href="/staflab/consumables") Home
                        li.breadcrumb-item.active Log Maintenance

    .content
        .container-fluid
            .card.card-primary.card-outline
                .card-header
                    h3.card-title
                        i.fas.fa-tools.mr-1
                        | Riwayat Maintenance Laboratorium
                    .card-tools
                        button#btn-expand-all.btn.btn-sm.btn-outline-primary.mr-1(type="button" title="Buka Semua Rincian BHP")
                            i.fas.fa-chevron-down.mr-1
                            | Buka Semua
                        button#btn-collapse-all.btn.btn-sm.btn-outline-secondary(type="button" title="Tutup Semua Rincian BHP")
                            i.fas.fa-chevron-up.mr-1
                            | Tutup Semua
                .card-body
                    .row.mb-3
                        .col-md-3
                            label.small.mb-1.text-muted Ruangan
                            select#filter-room.form-control.form-control-sm
                                option(value="") Semua Ruangan
                        .col-md-3
                            label.small.mb-1.text-muted Petugas
                            select#filter-staf.form-control.form-control-sm
                                option(value="") Semua Petugas
                        .col-md-3
                            label.small.mb-1.text-muted Urutkan
                            select#filter-sort.form-control.form-control-sm
                                option(value="") Default
                                option(value="abjad") Abjad (A-Z)
                                option(value="recent") Terbaru
                        .col-md-3.d-flex.align-items-end
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter
                    table#maintLogsTable.table.table-striped.table-bordered(style="width:100%")
                        thead
                            tr.bg-primary
                                th(style="width: 3%")
                                th.text-center(style="width: 5%") No.
                                th.text-center(style="width: 12%") Tanggal
                                th Nama Aset
                                th(style="width: 10%") Kode Label
                                th(style="width: 12%") Ruangan
                                th Deskripsi
                                th.text-center(style="width: 10%") Petugas
                                th.text-center(style="width: 8%") Detail
                        tbody
                            each log, index in logs
                                - var hasUsages = usagesByLog[log.id] && usagesByLog[log.id].length > 0
                                tr
                                    td.text-center.dt-expand-cell
                                        if hasUsages
                                            button.btn.btn-xs.btn-outline-info.btn-expand(type="button" title="Lihat BHP digunakan")
                                                i.fas.fa-plus
                                            .dt-child.d-none
                                                small.text-muted.mr-1
                                                    i.fas.fa-box-open.mr-1
                                                    | BHP Digunakan:
                                                each usage in usagesByLog[log.id]
                                                    span.badge.badge-warning.mr-1.mb-1.p-1 #{usage.consumable_name} (#{usage.quantity_used} #{usage.unit})
                                    td.text-center= index + 1
                                    td.text-center(data-order=(log.maintenance_date ? new Date(log.maintenance_date).getTime() : 0))= new Date(log.maintenance_date).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' })
                                    td.font-weight-bold= log.asset_name
                                    td
                                        code= log.label_code || '-'
                                    td= log.room_name || '-'
                                    td= log.description ? (log.description.length > 60 ? log.description.substring(0, 60) + '...' : log.description) : '-'
                                    td.text-center= log.staf_name
                                    td.text-center
                                        a.btn.btn-xs.btn-info(href=`/staflab/maintenance-logs/${log.id}` title="Lihat Detail")
                                            i.fas.fa-eye.mr-1
                                            | Detail

block scripts
    +dtScripts
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };
            var table = $('#maintLogsTable').DataTable({
                language: lang,
                pageLength: 10, lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Semua']],
                stateSave: true, stateDuration: -1,
                order: [[2, 'desc']],
                columnDefs: [{ targets: [0, 1, 8], orderable: false, searchable: false }]
            });
            table.on('draw.dt', function () {
                table.column(1, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });

            // --- Child-row helpers (rincian BHP) ---
            function showChild(row, tr) {
                if (!tr.find('.btn-expand').length) return;
                row.child('<div class="p-2">' + tr.find('.dt-child').html() + '</div>').show();
                tr.find('.btn-expand i').removeClass('fa-plus').addClass('fa-minus');
            }
            function hideChild(row, tr) {
                row.child.hide();
                tr.find('.btn-expand i').removeClass('fa-minus').addClass('fa-plus');
            }

            $('#maintLogsTable tbody').on('click', '.btn-expand', function () {
                var tr = $(this).closest('tr');
                var row = table.row(tr);
                if (row.child.isShown()) hideChild(row, tr); else showChild(row, tr);
            });

            $('#btn-expand-all').on('click', function () {
                table.rows().every(function () {
                    var tr = $(this.node());
                    if (tr.find('.btn-expand').length && !this.child.isShown()) showChild(this, tr);
                });
            });
            $('#btn-collapse-all').on('click', function () {
                table.rows().every(function () {
                    var tr = $(this.node());
                    if (this.child.isShown()) hideChild(this, tr);
                });
            });

            // --- Filter & Urutkan ---
            function exact(v) { return v ? '^' + $.fn.dataTable.util.escapeRegex(v) + '$' : ''; }
            function unanchor(s) { return s ? s.replace(/^\^/, '').replace(/\$$/, '').replace(/\\(.)/g, '$1') : ''; }

            // Isi dropdown Ruangan (col 5) & Petugas (col 7) dari nilai unik
            table.column(5).data().unique().sort().each(function (d) {
                var t = $('<div>').html(d).text().trim();
                if (t) $('#filter-room').append($('<option>').val(t).text(t));
            });
            table.column(7).data().unique().sort().each(function (d) {
                var t = $('<div>').html(d).text().trim();
                if (t) $('#filter-staf').append($('<option>').val(t).text(t));
            });

            $('#filter-room').on('change', function () { table.column(5).search(exact(this.value), true, false).draw(); });
            $('#filter-staf').on('change', function () { table.column(7).search(exact(this.value), true, false).draw(); });
            $('#filter-sort').on('change', function () {
                if (this.value === 'abjad') table.order([3, 'asc']).draw();
                else table.order([2, 'desc']).draw();
            });

            $('#btn-reset-filter').on('click', function () {
                $('#filter-room, #filter-staf, #filter-sort').val('');
                $('#maintLogsTable_filter input').val('');
                table.search('').columns().search('').order([[2, 'desc']]).draw();
            });

            // Sinkron dropdown dari state tersimpan (stateSave)
            $('#filter-room').val(unanchor(table.column(5).search()));
            $('#filter-staf').val(unanchor(table.column(7).search()));
            (function () {
                var o = table.order();
                if (o && o.length && o[0][0] === 3 && o[0][1] === 'asc') $('#filter-sort').val('abjad');
                else if (o && o.length && o[0][0] === 2 && o[0][1] === 'desc') $('#filter-sort').val('recent');
                else $('#filter-sort').val('');
            })();

            table.draw();
        });

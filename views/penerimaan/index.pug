extends ../layouts/master
include ../partials/dt-assets

block styles
    +dtStyles
    style.
        td.dt-expand-cell { cursor: pointer; }

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1.m-0 Penerimaan & Labeling Barang
                .col-sm-6
                    ol.breadcrumb.float-sm-right
                        li.breadcrumb-item
                            a(href="/stafadmin/assets") Home
                        li.breadcrumb-item.active Penerimaan & Labeling

    .content
        .container-fluid
            .card.card-primary.card-outline
                .card-header
                    h3.card-title
                        i.fas.fa-boxes.mr-1
                        | Daftar Barang Pengadaan Disetujui (Draf Locked)
                    .card-tools
                        button#btn-expand-all.btn.btn-sm.btn-outline-primary.mr-1(type="button" title="Buka Semua Riwayat")
                            i.fas.fa-chevron-down.mr-1
                            | Buka Semua
                        button#btn-collapse-all.btn.btn-sm.btn-outline-secondary(type="button" title="Tutup Semua Riwayat")
                            i.fas.fa-chevron-up.mr-1
                            | Tutup Semua
                .card-body
                    .d-flex.align-items-end.flex-nowrap.mb-3(style="gap: .5rem;")
                        div(style="flex: 2 1 0; min-width: 88px;")
                            label.small.mb-1.text-muted.text-nowrap Tahun
                            select#filter-year.form-control.form-control-sm
                                option(value="") Semua Tahun
                        div(style="flex: 2 1 0; min-width: 92px;")
                            label.small.mb-1.text-muted.text-nowrap Jenis
                            select#filter-type.form-control.form-control-sm
                                option(value="") Semua Jenis
                                option(value="Inventaris") Inventaris
                                option(value="BHP") BHP
                        div(style="flex: 3 1 0; min-width: 110px;")
                            label.small.mb-1.text-muted.text-nowrap Tipe
                            select#filter-tipe.form-control.form-control-sm
                                option(value="") Semua Tipe
                                option(value="Barang Baru") Barang Baru
                                option(value="Barang Pengganti") Barang Pengganti
                        div(style="flex: 3 1 0; min-width: 132px;")
                            label.small.mb-1.text-muted.text-nowrap Status Penerimaan
                            select#filter-status.form-control.form-control-sm
                                option(value="") Semua Status
                                option(value="Belum Diterima") Belum Diterima
                                option(value="Diterima Sebagian") Diterima Sebagian
                                option(value="Selesai Diterima") Selesai Diterima
                        div(style="flex: 5 1 0; min-width: 150px;")
                            label.small.mb-1.text-muted.text-nowrap Registrasi Aset
                            select#filter-registration.form-control.form-control-sm
                                option(value="") Semua Registrasi Aset
                                option(value="pending") Masih bisa Daftar ke Inventaris
                                option(value="done") Sudah terdaftar ke Inventaris
                        div(style="flex: 2 1 0; min-width: 96px;")
                            label.small.mb-1.text-muted.text-nowrap Urutkan
                            select#filter-sort.form-control.form-control-sm
                                option(value="") Default
                                option(value="abjad") Abjad (A-Z)
                                option(value="recent") Terbaru
                        div(style="flex: 2 1 0; min-width: 104px;")
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter

                    table#penerimaanTable.table.table-striped.table-bordered(style="width:100%")
                        thead
                            tr.bg-primary
                                th(style="width: 3%")
                                th.text-center(style="width: 2%") No.
                                th.text-center(style="width: 5%") Tahun
                                th Nama Barang
                                th.text-center(style="width: 5%") Jenis
                                th.text-center(style="width: 8%") Tipe
                                th.text-right(style="width: 10%") Harga Estimasi
                                th.text-center(style="width: 18%") Jumlah Diterima
                                th.text-center(style="width: 8%") Status
                                th.text-center(style="width: 5%") Link
                                th.text-center(style="width: 12%") Terima
                                th Registrasi
                        tbody
                            each item, index in items
                                - const hasReceipts = receiptsByItem[item.item_id] && receiptsByItem[item.item_id].length > 0
                                - const hasUnregistered = item.item_type === 'Inventaris' && hasReceipts && receiptsByItem[item.item_id].some(r => !r.is_registered)
                                - let regToken = 'none'
                                - if (item.item_type === 'Inventaris' && hasReceipts) regToken = hasUnregistered ? 'pending' : 'done'
                                tr
                                    td.text-center.dt-expand-cell
                                        button.btn.btn-xs.btn-expand(type="button" class=(hasUnregistered ? 'btn-outline-info' : 'btn-outline-secondary') title="Riwayat Penerimaan & Registrasi")
                                            i.fas.fa-chevron-down
                                        .dt-child.d-none
                                            .card.card-outline.card-info.mb-0
                                                .card-body.p-0
                                                    if hasReceipts
                                                        table.table.table-sm.table-valign-middle.table-striped.mb-0
                                                            thead.bg-info.text-white
                                                                tr
                                                                    th.pl-3 No.
                                                                    th Tanggal Diterima
                                                                    th Jumlah Diterima
                                                                    th Petugas
                                                                    if item.item_type === 'Inventaris'
                                                                        th.text-center.pr-3 Registrasi Aset
                                                            tbody
                                                                each rec, rIdx in receiptsByItem[item.item_id]
                                                                    tr
                                                                        td.pl-3= rIdx + 1
                                                                        td= new Date(rec.received_date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })
                                                                        td.font-weight-bold= `${rec.quantity_received} unit`
                                                                        td= rec.receiver_name
                                                                        if item.item_type === 'Inventaris'
                                                                            td.text-center.pr-3
                                                                                if rec.is_registered
                                                                                    span.badge.badge-secondary.p-2
                                                                                        i.fas.fa-lock.mr-1
                                                                                        | Sudah Terdaftar
                                                                                else
                                                                                    a.btn.btn-xs.btn-success(href=`/stafadmin/receipt/${rec.receipt_id}/register-asset`)
                                                                                        i.fas.fa-barcode.mr-1
                                                                                        | Daftarkan ke Inventaris
                                                    else
                                                        .p-3.text-muted.text-center(style="background-color: #fff;")
                                                            i.fas.fa-inbox.mr-1
                                                            | Belum ada penerimaan yang diinput.
                                    td.text-center= index + 1
                                    td.text-center
                                        span.badge.badge-secondary= item.year
                                    td.font-weight-bold= item.item_name
                                    td.text-center(data-search=item.item_type)
                                        if item.item_type === 'Inventaris'
                                            span.badge.badge-primary
                                                i.fas.fa-desktop.mr-1
                                                | Inventaris
                                        else
                                            span.badge.badge-warning
                                                i.fas.fa-box-open.mr-1
                                                | BHP
                                    td.text-center(data-search=item.target_replacement_asset_id ? 'Barang Pengganti' : 'Barang Baru')
                                        if item.target_replacement_asset_id
                                            span.badge.badge-danger
                                                i.fas.fa-exchange-alt.mr-1
                                                | Barang Pengganti
                                        else
                                            span.badge.badge-light.border
                                                i.fas.fa-plus.mr-1
                                                | Barang Baru
                                    td.text-right(data-order=item.price)= 'Rp ' + Number(item.price).toLocaleString('id-ID')
                                    td.text-center(data-order=item.quantity_received)
                                        div.d-flex.align-items-center.justify-content-left
                                            .progress.flex-grow-1.mr-2(style="height: 12px; min-width: 80px; max-width: 70%;")
                                                - const percent = Math.min(100, Math.round((item.quantity_received / item.target_quantity) * 100))
                                                - const barColor = percent === 100 ? 'bg-success' : (percent > 0 ? 'bg-warning' : 'bg-danger')
                                                .progress-bar(class=barColor role="progressbar" style=`width: ${percent}%` aria-valuenow=percent aria-valuemin="0" aria-valuemax="100")
                                            span.small.font-weight-bold(style="white-space: nowrap;")= `${item.quantity_received}/${item.target_quantity}`
                                    td.text-center
                                        if item.quantity_received == 0
                                            span.badge.badge-danger.p-2
                                                i.fas.fa-times-circle.mr-1
                                                | Belum Diterima
                                        else if item.quantity_received < item.target_quantity
                                            span.badge.badge-warning.p-2
                                                i.fas.fa-hourglass-half.mr-1
                                                | Diterima Sebagian
                                        else
                                            span.badge.badge-success.p-2
                                                i.fas.fa-check-circle.mr-1
                                                | Selesai Diterima
                                    td.text-center
                                        if item.purchase_link
                                            a.btn.btn-xs.btn-info(href=item.purchase_link target="_blank" title="Buka Link Pembelian")
                                                i.fas.fa-external-link-alt.mr-1
                                                | Link
                                        else
                                            span.text-muted -
                                    td.text-center
                                        if item.quantity_received < item.target_quantity
                                            a.btn.btn-sm.btn-primary.w-100(href=`/stafadmin/procurement/${item.item_id}/receipt`)
                                                i.fas.fa-plus-circle.mr-1
                                                | Sisa #{item.target_quantity - item.quantity_received}
                                        else
                                            span.text-success
                                                i.fas.fa-check-double
                                                |  Lengkap
                                    td= regToken

block scripts
    +dtScripts
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };
            var table = $('#penerimaanTable').DataTable({
                language: lang,
                pageLength: 10, lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Semua']],
                stateSave: true, stateDuration: -1,
                order: [[3, 'asc']],
                columnDefs: [
                    { targets: [0, 1, 9, 10], orderable: false, searchable: false },
                    { targets: 11, visible: false, orderable: false }
                ]
            });
            table.on('draw.dt', function () {
                table.column(1, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });

            function showChild(rowApi, tr) {
                rowApi.child('<div class="px-3 py-2" style="background-color:#f4f6f9;">' + tr.find('.dt-child').html() + '</div>').show();
                tr.find('.btn-expand i').removeClass('fa-chevron-down').addClass('fa-chevron-up');
            }
            function hideChild(rowApi, tr) {
                rowApi.child.hide();
                tr.find('.btn-expand i').removeClass('fa-chevron-up').addClass('fa-chevron-down');
            }

            $('#penerimaanTable tbody').on('click', '.btn-expand', function () {
                var tr = $(this).closest('tr');
                var row = table.row(tr);
                if (row.child.isShown()) hideChild(row, tr); else showChild(row, tr);
            });

            $('#btn-expand-all').on('click', function () {
                table.rows().every(function () { var tr = $(this.node()); if (!this.child.isShown()) showChild(this, tr); });
            });
            $('#btn-collapse-all').on('click', function () {
                table.rows().every(function () { var tr = $(this.node()); if (this.child.isShown()) hideChild(this, tr); });
            });

            function exact(v) { return v ? '^' + $.fn.dataTable.util.escapeRegex(v) + '$' : ''; }
            function unanchor(s) { return s ? s.replace(/^\^/, '').replace(/\$$/, '').replace(/\\(.)/g, '$1') : ''; }

            // Isi dropdown Tahun dari nilai unik kolom Tahun (col 2)
            table.column(2).data().unique().sort().each(function (d) {
                var t = $('<div>').html(d).text().trim();
                if (t) $('#filter-year').append($('<option>').val(t).text(t));
            });

            $('#filter-year').on('change',         function () { table.column(2).search(exact(this.value), true, false).draw(); });
            $('#filter-type').on('change',         function () { table.column(4).search(exact(this.value), true, false).draw(); });
            $('#filter-tipe').on('change',         function () { table.column(5).search(exact(this.value), true, false).draw(); });
            $('#filter-status').on('change',       function () { table.column(8).search(exact(this.value), true, false).draw(); });
            $('#filter-registration').on('change', function () { table.column(11).search(exact(this.value), true, false).draw(); });
            $('#filter-sort').on('change', function () {
                if (this.value === 'recent') table.order([2, 'desc']).draw();
                else table.order([3, 'asc']).draw();
            });

            $('#btn-reset-filter').on('click', function () {
                $('#filter-year, #filter-type, #filter-tipe, #filter-status, #filter-registration, #filter-sort').val('');
                $('#penerimaanTable_filter input').val('');
                table.search('').columns().search('').order([[3, 'asc']]).draw();
            });

            // Sinkron dropdown dari state tersimpan (stateSave)
            $('#filter-year').val(unanchor(table.column(2).search()));
            $('#filter-type').val(unanchor(table.column(4).search()));
            $('#filter-tipe').val(unanchor(table.column(5).search()));
            $('#filter-status').val(unanchor(table.column(8).search()));
            $('#filter-registration').val(unanchor(table.column(11).search()));
            (function () {
                var o = table.order();
                if (o && o.length) {
                    var col = o[0][0], dir = o[0][1];
                    if (col === 2 && dir === 'desc') $('#filter-sort').val('recent');
                    else if (col === 3 && dir === 'asc') $('#filter-sort').val('abjad');
                    else $('#filter-sort').val('');
                }
            })();

            table.draw();
        });

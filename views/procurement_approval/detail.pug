extends ../layouts/master

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Detail & Pengesahan Draft

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Informasi Detail Pengadaan Tahunan

                .card-body
                    .row.mb-4
                        .col-md-4
                            strong Kepala Laboratorium (Pembuat):
                            p= draft.kalab_name
                        .col-md-4
                            strong Tahun Pengadaan:
                            p= draft.year
                        .col-md-4
                            strong Status Draft:
                            p
                                if draft.status == 'Draft'
                                    span.badge.badge-warning Draft
                                else if draft.status == 'Reviewed'
                                    span.badge.badge-info Reviewed
                                else if draft.status == 'Locked'
                                    span.badge.badge-success Locked

                    h5.border-bottom.pb-2.mb-3 Daftar Barang yang Diajukan

                    .table-responsive
                        table.table.table-bordered.table-striped
                            thead
                                tr
                                    th No
                                    th Jenis Barang
                                    th Nama Barang
                                    th Harga Satuan
                                    th Qty
                                    th Subtotal
                                    th Link Pembelian
                                    th Aset yang Diganti
                                    th Status Persetujuan
                            tbody
                                if items.length === 0
                                    tr
                                        td.text-center(colspan="9") Tidak ada barang di draft pengadaan ini.
                                else
                                    each item, index in items
                                        tr
                                            td= index + 1
                                            td= item.item_type
                                            td= item.item_name
                                            td Rp. #{Number(item.price).toLocaleString('id-ID')}
                                            td= item.quantity
                                            td Rp. #{Number(item.price * item.quantity).toLocaleString('id-ID')}
                                            td
                                                if item.purchase_link
                                                    a(href=item.purchase_link target="_blank") Lihat Link
                                                else
                                                    span.text-muted -
                                            td
                                                if item.replaced_asset_name
                                                    span= item.replaced_asset_name
                                                    if item.replaced_asset_label
                                                        span.text-muted  (#{item.replaced_asset_label})
                                                else
                                                    span.text-muted -
                                            td
                                                if item.status === 'Disetujui'
                                                    span.badge.badge-success Disetujui
                                                else if item.status === 'Ditolak'
                                                    span.badge.badge-danger Ditolak
                                                else
                                                    span.badge.badge-secondary Pending

                    - let hasPending = items.some(item => item.status === 'Pending')

                    if draft.status === 'Locked'
                        .alert.alert-success.mt-3
                            i.fas.fa-check-circle
                            |  Draft sudah disahkan dan tidak dapat diubah lagi.
                    else if hasPending
                        .alert.alert-warning.mt-4
                            i.fas.fa-exclamation-triangle
                            |  Draft ini tidak dapat disahkan karena masih ada item dengan status <strong>Pending</strong>. Silakan lakukan review persetujuan terlebih dahulu pada menu "Draft Pengadaan".

                .card-footer
                    a.btn.btn-default(href="/kaprodi/procurement-approval")
                        i.fas.fa-arrow-left
                        |  Kembali

                    if draft.status !== 'Locked'
                        form(
                            action=`/kaprodi/procurement-approval/detail/${draft.id}/approve`
                            method="POST"
                            style="display: inline-block; float: right;"
                            onsubmit="return confirm('Apakah Anda yakin ingin mengesahkan draft pengadaan ini? Setelah disahkan, status draft akan terkunci (Locked) dan tidak dapat diubah lagi.');"
                        )
                            button.btn.btn-success(type="submit" disabled=hasPending)
                                i.fas.fa-check-double
                                |  Sahkan Draft
                    else
                        button.btn.btn-secondary.float-right(disabled)
                            i.fas.fa-lock
                            |  Sudah Disahkan (Locked)

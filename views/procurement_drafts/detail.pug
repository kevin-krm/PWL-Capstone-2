extends ../layouts/master

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Detail Draft Pengadaan

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Informasi Detail Pengadaan Tahunan

                .card-body
                    .row.mb-4
                        .col-md-4
                            strong Kepala Laboratorium (Pembuat):
                            p= draft.kalab_name
                        .col-md-4
                            strong Tahun Pengadaan:
                            p= draft.year
                        .col-md-4
                            strong Status Draft:
                            p
                                if draft.status == 'Draft'
                                    span.badge.badge-warning Draft
                                else if draft.status == 'Reviewed'
                                    span.badge.badge-info Reviewed
                                else if draft.status == 'Locked'
                                    span.badge.badge-success Locked

                    h5.border-bottom.pb-2.mb-3 Daftar Barang yang Diajukan

                    .table-responsive
                        table.table.table-bordered.table-striped
                            thead
                                tr
                                    th No
                                    th Jenis Barang
                                    th Nama Barang
                                    th Alasan Pengadaan
                                    th Harga Satuan
                                    th Qty
                                    th Subtotal
                                    th Link Pembelian
                                    th Aset yang Diganti
                                    th Status Persetujuan
                                    th Alasan Kaprodi
                            tbody
                                if items.length === 0
                                    tr
                                        td.text-center(colspan="11") Tidak ada barang di draft pengadaan ini.
                                else
                                    each item, index in items
                                        tr
                                            td= index + 1
                                            td= item.item_type
                                            td= item.item_name
                                            td= item.reason
                                            td Rp. #{Number(item.price).toLocaleString('id-ID')}
                                            td= item.quantity
                                            td Rp. #{Number(item.price * item.quantity).toLocaleString('id-ID')}
                                            td
                                                if item.purchase_link
                                                    a(href=item.purchase_link target="_blank") Lihat Link
                                                else
                                                    span.text-muted -
                                            td
                                                if item.replaced_asset_name
                                                    span= item.replaced_asset_name
                                                    if item.replaced_asset_label
                                                        span.text-muted  (#{item.replaced_asset_label})
                                                else
                                                    span.text-muted -
                                            td
                                                if item.status === 'Disetujui'
                                                    span.badge.badge-success Disetujui
                                                else if item.status === 'Ditolak'
                                                    span.badge.badge-danger Ditolak
                                                else
                                                    span.badge.badge-secondary Pending
                                            td= item.final_reason || '-'

                .card-footer
                    a.btn.btn-default(href="/kalab/procurement-drafts")
                        i.fas.fa-arrow-left
                        |  Kembali

                    if draft.status === 'Draft'
                        form.float-right(action=`/kalab/procurement-drafts/${draft.id}/submit` method="POST" style="display:inline;")
                            button.btn.btn-success(type="submit" onclick="return confirm('Ajukan draft ini ke Ketua Program Studi? Setelah diajukan, draft tidak dapat diubah/dihapus lagi.');")
                                i.fas.fa-paper-plane
                                |  Ajukan ke Kaprodi
                        a.btn.btn-warning.float-right.mr-2(href=`/kalab/procurement-drafts/edit/${draft.id}`)
                            i.fas.fa-edit
                            |  Edit Draft
                    else if draft.status === 'Reviewed'
                        button.btn.btn-info.float-right(disabled)
                            i.fas.fa-hourglass-half
                            |  Menunggu Review Kaprodi
                    else
                        button.btn.btn-secondary.float-right(disabled)
                            i.fas.fa-lock
                            |  Draft Terkunci (Locked)

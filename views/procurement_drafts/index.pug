extends ../layouts/master
include ../partials/dt-assets

block styles
    +dtStyles

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Draft Pengadaan

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Daftar Draft Pengadaan Tahunan
                    .card-tools
                        a.btn.btn-primary.btn-sm(href="/kalab/procurement-drafts/create")
                            i.fas.fa-plus
                            |  Tambah Draft Pengadaan
                .card-body
                    .row.mb-3
                        .col-md-3
                            label.small.mb-1.text-muted Tahun
                            select#filter-year.form-control.form-control-sm
                                option(value="") Semua Tahun
                                each year in years
                                    option(value=year)= year
                        .col-md-3
                            label.small.mb-1.text-muted Status
                            select#filter-status.form-control.form-control-sm
                                option(value="") Semua Status
                                option(value="Draft") Draft
                                option(value="Reviewed") Reviewed
                                option(value="Locked") Locked
                        .col-md-3.d-flex.align-items-end
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter

                    table#draftsTable.table.table-bordered.table-striped(style="width:100%")
                        thead.bg-primary
                            tr
                                th No
                                th Tahun
                                th.text-center Status
                                th.text-center Tanggal Dibuat
                                th.text-center Aksi
                        tbody
                            each draft, index in drafts
                                tr
                                    td= index + 1
                                    td= draft.year
                                    td.text-center
                                        if draft.status == 'Draft'
                                            span.badge.badge-warning Draft
                                        else if draft.status == 'Reviewed'
                                            span.badge.badge-info Reviewed
                                        else if draft.status == 'Locked'
                                            span.badge.badge-success Locked
                                    td.text-center(data-order=(draft.created_at ? new Date(draft.created_at).getTime() : 0))= new Date(draft.created_at).toLocaleDateString('id-ID')
                                    td.text-center
                                        .d-flex.flex-wrap.justify-content-center
                                            a.btn.btn-info.btn-sm.m-1(href=`/kalab/procurement-drafts/${draft.id}`)
                                                i.fas.fa-eye
                                                |  Detail
                                            if draft.status === 'Draft'
                                                form.m-1(action=`/kalab/procurement-drafts/${draft.id}/submit` method="POST" style="display:inline;")
                                                    button.btn.btn-success.btn-sm(type="submit" onclick="return confirm('Ajukan draft ini ke Ketua Program Studi? Setelah diajukan, draft tidak dapat diubah/dihapus lagi.');")
                                                        i.fas.fa-paper-plane
                                                        |  Ajukan
                                                form.m-1(action=`/kalab/procurement-drafts/delete/${draft.id}` method="POST" style="display:inline;")
                                                    button.btn.btn-danger.btn-sm(type="submit" onclick="return confirm('Apakah Anda yakin ingin menghapus draft pengadaan ini? Semua barang di dalamnya juga akan terhapus.');")
                                                        i.fas.fa-trash
                                                        |  Hapus
                                            else if draft.status === 'Reviewed'
                                                button.btn.btn-info.btn-sm.m-1(disabled)
                                                    i.fas.fa-hourglass-half
                                                    |  Menunggu Review
                                            else
                                                button.btn.btn-secondary.btn-sm.m-1(disabled)
                                                    i.fas.fa-lock
                                                    |  Locked

block scripts
    +dtScripts
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };
            var table = $('#draftsTable').DataTable({
                language: lang,
                pageLength: 10, lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Semua']],
                stateSave: true, stateDuration: -1,
                order: [[3, 'desc']],
                columnDefs: [{ targets: [0, 4], orderable: false, searchable: false }]
            });
            table.on('draw.dt', function () {
                table.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });

            function exact(v) { return v ? '^' + $.fn.dataTable.util.escapeRegex(v) + '$' : ''; }
            function unanchor(s) { return s ? s.replace(/^\^/, '').replace(/\$$/, '').replace(/\\(.)/g, '$1') : ''; }
            $('#filter-year').on('change',   function () { table.column(1).search(exact(this.value), true, false).draw(); });
            $('#filter-status').on('change', function () { table.column(2).search(this.value, false, true).draw(); });

            $('#btn-reset-filter').on('click', function () {
                $('#filter-year, #filter-status').val('');
                $('#draftsTable_filter input').val('');
                table.search('').columns().search('').order([[3, 'desc']]).draw();
            });

            // Sinkron dropdown dari state tersimpan (stateSave)
            $('#filter-year').val(unanchor(table.column(1).search()));
            $('#filter-status').val(table.column(2).search());

            table.draw();
        });

extends ../layouts/master

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Review Draft Pengadaan

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Detail Draft Pengadaan

                .card-body
                    .row.mb-3
                        .col-md-4
                            strong Tahun:
                            p= draft.year

                        .col-md-4
                            strong Kepala Laboratorium:
                            p= draft.kalab_name

                        .col-md-4
                            strong Status Draft:

                            if draft.status === 'Locked'
                                span.badge.badge-success Locked
                            else if draft.status === 'Reviewed'
                                span.badge.badge-info Reviewed
                            else
                                span.badge.badge-warning Draft

                    form(
                        action=`/kaprodi/procurement-review/edit/${draft.id}/finalize`
                        method='POST'
                        onsubmit="return confirm('Apakah Anda yakin ingin memfinalisasi draft pengadaan ini? Draft yang sudah difinalisasi akan dikunci (Locked) dan tidak dapat diubah lagi.')"
                    )
                        table.table.table-bordered.table-striped
                            thead
                                tr
                                    th No
                                    th Nama Barang
                                    th Jenis
                                    th Harga
                                    th Qty
                                    th Link Pembelian
                                    th Alasan Pengadaan
                                    th Aset yang Diganti
                                    th Status Persetujuan
                                    th Alasan Kaprodi

                            tbody
                                each item, index in items
                                    tr
                                        td= index + 1
                                        td= item.item_name
                                        td= item.item_type
                                        td
                                            | Rp.
                                            = Number(item.price).toLocaleString('id-ID')
                                        td= item.quantity
                                        td
                                            if item.purchase_link
                                                a(
                                                    href=item.purchase_link
                                                    target='_blank'
                                                ) Lihat Link
                                            else
                                                span.text-muted Tidak ada link
                                        td= item.reason
                                        td
                                            if item.replaced_asset_name
                                                span= item.replaced_asset_name
                                                if item.replaced_asset_label
                                                    span.text-muted  (#{item.replaced_asset_label})
                                            else
                                                span.text-muted -
                                        td
                                            if draft.status === 'Locked'
                                                if item.status === 'Disetujui'
                                                    span.badge.badge-success Disetujui
                                                else if item.status === 'Ditolak'
                                                    span.badge.badge-danger Ditolak
                                                else
                                                    span.badge.badge-secondary Pending
                                            else
                                                input(
                                                    type='hidden'
                                                    name='item_ids[]'
                                                    value=item.id
                                                )
                                                select.form-control(name='statuses[]')
                                                    if item.status === 'Pending'
                                                        option(
                                                            value='Pending'
                                                            disabled
                                                            selected
                                                        ) Pending
                                                    option(
                                                        value='Disetujui'
                                                        selected=(item.status === 'Disetujui')
                                                    ) Disetujui

                                                    option(
                                                        value='Ditolak'
                                                        selected=(item.status === 'Ditolak')
                                                    ) Ditolak
                                        td
                                            if draft.status === 'Locked'
                                                = item.final_reason || '-'
                                            else
                                                input.form-control(type="text" name="final_reasons[]" value=item.final_reason placeholder="Alasan (opsional)")

                        if draft.status === 'Locked'
                            .alert.alert-success.mt-3
                                i.fas.fa-check-circle
                                |  Draft sudah difinalisasi dan tidak dapat diubah lagi.

                        .card-footer.mt-4.px-0.pb-0(style="background: transparent; border-top: 1px solid #dee2e6;")
                            a.btn.btn-default(href="/kaprodi/procurement-review")
                                i.fas.fa-arrow-left
                                |  Kembali

                            if draft.status !== 'Locked'
                                button.btn.btn-success.float-right(type='submit')
                                    i.fas.fa-check
                                    |  Finalisasi
                            else
                                button.btn.btn-secondary.float-right(disabled)
                                    i.fas.fa-lock
                                    |  Sudah Difinalisasi
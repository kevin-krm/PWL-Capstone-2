extends ../layouts/master
include ../partials/dt-assets

block styles
    +dtStyles

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Data Ruangan Laboratorium

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Daftar Ruangan GWT 8
                    .card-tools
                        button.btn.btn-primary.btn-sm(data-toggle="modal" data-target="#modal-tambah")
                            i.fas.fa-plus
                            |  Tambah Ruangan
                .card-body
                    .row.mb-3
                        .col-md-3.d-flex.align-items-end
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter

                    table#roomsTable.table.table-bordered.table-hover(style="width:100%")
                        thead.bg-primary
                            tr
                                th No.
                                th Nama Ruangan
                                th Deskripsi
                                th.text-center Aksi
                        tbody
                            each r, index in rooms
                                tr
                                    td= index + 1
                                    td= r.room_name
                                    td= r.description
                                    td.text-center
                                        .d-flex.flex-wrap.justify-content-center
                                            button.btn.btn-sm.btn-warning.m-1(data-toggle="modal" data-target=`#modal-edit-${r.id}`) Edit
                                            form.m-1(action=`/admin/rooms/delete/${r.id}` method="POST" style="display:inline;")
                                                button.btn.btn-sm.btn-danger(type="submit" onclick="return confirm('Yakin ingin menghapus ruangan ini?');") Hapus

            //- ==========================================
            //- MODAL (di luar tabel agar DataTables tidak rusak)
            //- ==========================================
            each r in rooms
                .modal.fade(id=`modal-edit-${r.id}`)
                    .modal-dialog
                        .modal-content
                            .modal-header
                                h4.modal-title Edit Ruangan
                                button.close(type="button" data-dismiss="modal" aria-label="Close")
                                    span(aria-hidden="true") &times;
                            form(action=`/admin/rooms/edit/${r.id}` method="POST")
                                .modal-body
                                    .form-group
                                        label Nama Ruangan
                                        input.form-control(type="text" name="room_name" value=r.room_name required)
                                    .form-group
                                        label Deskripsi
                                        textarea.form-control(name="description" rows="3" required)= r.description
                                .modal-footer.justify-content-between
                                    button.btn.btn-default(type="button" data-dismiss="modal") Batal
                                    button.btn.btn-primary(type="submit") Simpan Perubahan

            // MODAL TAMBAH RUANGAN
            .modal.fade#modal-tambah
                .modal-dialog
                    .modal-content
                        .modal-header
                            h4.modal-title Tambah Ruangan Baru
                            button.close(type="button" data-dismiss="modal" aria-label="Close")
                                span(aria-hidden="true") &times;
                        form(action="/admin/rooms/add" method="POST")
                            .modal-body
                                .form-group
                                    label Nama Ruangan
                                    input.form-control(type="text" name="room_name" placeholder="Misal: Lab Basis Data R5" required)
                                .form-group
                                    label Deskripsi
                                    textarea.form-control(name="description" rows="3" placeholder="Deskripsi atau lokasi ruangan" required)
                            .modal-footer.justify-content-between
                                button.btn.btn-default(type="button" data-dismiss="modal") Batal
                                button.btn.btn-primary(type="submit") Simpan Ruangan

block scripts
    +dtScripts
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };
            var table = $('#roomsTable').DataTable({
                language: lang,
                pageLength: 10, lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Semua']],
                stateSave: true, stateDuration: -1,
                order: [[1, 'asc']],
                columnDefs: [{ targets: [0, 3], orderable: false, searchable: false }]
            });
            table.on('draw.dt', function () {
                table.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });
            $('#btn-reset-filter').on('click', function () {
                $('#roomsTable_filter input').val('');
                table.search('').columns().search('').order([[1, 'asc']]).draw();
            });
            table.draw();
        });

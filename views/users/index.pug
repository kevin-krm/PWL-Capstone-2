extends ../layouts/master

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Data Pengguna

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Daftar Pengguna Sistem
                    .card-tools
                        a.btn.btn-primary.btn-sm(href="/admin/users/create")
                            i.fas.fa-plus
                            |  Tambah Pengguna
                .card-body
                    form.row.mb-3(method="GET" action="/admin/users")
                        .col-md-3
                            select.form-control.form-control-sm(name="role" onchange="this.form.submit()")
                                option(value="" selected=(!selectedRole)) Semua Role
                                option(value="Administrator" selected=(selectedRole == 'Administrator')) Administrator
                                option(value="Kepala Laboratorium" selected=(selectedRole == 'Kepala Laboratorium')) Kepala Laboratorium
                                option(value="Ketua Program Studi" selected=(selectedRole == 'Ketua Program Studi')) Ketua Program Studi
                                option(value="Staf Administrasi" selected=(selectedRole == 'Staf Administrasi')) Staf Administrasi
                                option(value="Staf Laboratorium" selected=(selectedRole == 'Staf Laboratorium')) Staf Laboratorium
                        .col-md-3
                            select.form-control.form-control-sm(name="status" onchange="this.form.submit()")
                                option(value="" selected=(!selectedStatus)) Semua Status
                                option(value="active" selected=(selectedStatus == 'active')) Aktif
                                option(value="inactive" selected=(selectedStatus == 'inactive')) Nonaktif
                        .col-md-3
                            select.form-control.form-control-sm(name="sort" onchange="this.form.submit()")
                                option(value="" selected=(!selectedSort)) Urutkan
                                option(value="abjad" selected=(selectedSort == 'abjad')) Abjad (A-Z)
                                option(value="recent" selected=(selectedSort == 'recent')) Terbaru
                        .col-md-3
                            a.btn.btn-secondary.btn-sm.btn-block(href="/admin/users")
                                i.fas.fa-undo
                                |  Reset Filter

                    table.table.table-bordered
                        thead.bg-primary
                            tr
                                th No.
                                th Nama
                                th Email
                                th Role
                                th Status
                                th Aksi
                        tbody
                            each u, index in users
                                tr
                                    td= index + 1
                                    td= u.name
                                    td= u.email
                                    td= u.role
                                    td
                                        if u.is_active == 1
                                            span.badge.badge-success Aktif
                                        else
                                            span.badge.badge-danger Nonaktif
                                    td
                                        a.btn.btn-sm.btn-warning(href=`/admin/users/edit/${u.id}`) Edit
                                        form(action=`/admin/users/delete/${u.id}` method="POST" style="display:inline;")
                                            button.btn.btn-sm.btn-danger.ml-1(type="submit" onclick="return confirm('Yakin ingin menghapus pengguna ini?');") Hapus
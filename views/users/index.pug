extends ../layouts/master
include ../partials/dt-assets

block styles
    +dtStyles

block content
    .content-header
        .container-fluid
            .row.mb-2
                .col-sm-6
                    h1 Data Pengguna

    .content
        .container-fluid
            .card
                .card-header
                    h3.card-title Daftar Pengguna Sistem
                    .card-tools
                        a.btn.btn-primary.btn-sm(href="/admin/users/create")
                            i.fas.fa-plus
                            |  Tambah Pengguna
                .card-body
                    .row.mb-3
                        .col-md-4
                            label.small.mb-1.text-muted Role
                            select#filter-role.form-control.form-control-sm
                                option(value="") Semua Role
                                option(value="Administrator") Administrator
                                option(value="Kepala Laboratorium") Kepala Laboratorium
                                option(value="Ketua Program Studi") Ketua Program Studi
                                option(value="Staf Administrasi") Staf Administrasi
                                option(value="Staf Laboratorium") Staf Laboratorium
                        .col-md-4
                            label.small.mb-1.text-muted Status
                            select#filter-status.form-control.form-control-sm
                                option(value="") Semua Status
                                option(value="Aktif") Aktif
                                option(value="Nonaktif") Nonaktif
                        .col-md-4.d-flex.align-items-end
                            button#btn-reset-filter.btn.btn-secondary.btn-sm.btn-block(type="button")
                                i.fas.fa-undo.mr-1
                                | Reset Filter

                    table#usersTable.table.table-bordered.table-hover(style="width:100%")
                        thead.bg-primary
                            tr
                                th No.
                                th Nama
                                th Email
                                th Role
                                th.text-center Status
                                th.text-center Aksi
                        tbody
                            each u, index in users
                                tr
                                    td= index + 1
                                    td= u.name
                                    td= u.email
                                    td= u.role
                                    td.text-center
                                        if u.is_active == 1
                                            span.badge.badge-success Aktif
                                        else
                                            span.badge.badge-danger Nonaktif
                                    td
                                        .d-flex.flex-wrap.justify-content-center
                                            a.btn.btn-sm.btn-warning.m-1(href=`/admin/users/edit/${u.id}`) Edit
                                            form.m-1(action=`/admin/users/delete/${u.id}` method="POST" style="display:inline;")
                                                button.btn.btn-sm.btn-danger(type="submit" onclick="return confirm('Yakin ingin menghapus pengguna ini?');") Hapus

block scripts
    +dtScripts
    script.
        $(function () {
            var lang = {
                search: "Cari:", lengthMenu: "Tampilkan _MENU_ data", zeroRecords: "Tidak ditemukan data yang cocok",
                info: "Menampilkan _START_–_END_ dari _TOTAL_ data", infoEmpty: "Tidak ada data",
                infoFiltered: "(disaring dari _MAX_ total)",
                paginate: { first: "Awal", last: "Akhir", next: "›", previous: "‹" }
            };
            var table = $('#usersTable').DataTable({
                language: lang,
                pageLength: 10, lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Semua']],
                stateSave: true, stateDuration: -1,
                order: [[1, 'asc']],
                columnDefs: [{ targets: [0, 5], orderable: false, searchable: false }]
            });
            table.on('draw.dt', function () {
                table.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (c, i) { c.innerHTML = i + 1; });
            });

            function exact(v) { return v ? '^' + $.fn.dataTable.util.escapeRegex(v) + '$' : ''; }
            function unanchor(s) { return s ? s.replace(/^\^/, '').replace(/\$$/, '').replace(/\\(.)/g, '$1') : ''; }
            $('#filter-role').on('change',   function () { table.column(3).search(exact(this.value), true, false).draw(); });
            $('#filter-status').on('change', function () { table.column(4).search(exact(this.value), true, false).draw(); });

            $('#btn-reset-filter').on('click', function () {
                $('#filter-role, #filter-status').val('');
                $('#usersTable_filter input').val('');
                table.search('').columns().search('').order([[1, 'asc']]).draw();
            });

            // Sinkron dropdown dari state tersimpan (stateSave)
            $('#filter-role').val(unanchor(table.column(3).search()));
            $('#filter-status').val(unanchor(table.column(4).search()));

            table.draw();
        });
